# Copy this file to backend/.env.docker and fill actual values.

# Supabase + Prisma
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# App
PORT=8000
NODE_ENV=production
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=fyatta-backend
LOG_REDACT_KEYS=password,token,secret,authorization,signature

# JWT
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=refreshToken
COOKIE_SAME_SITE=lax
MAX_MENU_ITEMS_PER_REQUEST=50

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:3000/oauth/callback
GOOGLE_FRONTEND_FAILURE_URL=http://localhost:3000/login

# General API rate limit
RATE_LIMIT_API_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_API_MAX=600

# Authentication endpoints (login, register, password reset, etc.)
RATE_LIMIT_AUTH_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_AUTH_MAX=20

# Public write endpoints (POST/PUT/PATCH by unauthenticated users)
RATE_LIMIT_PUBLIC_WRITE_WINDOW_MS=600000   # 10 minutes
RATE_LIMIT_PUBLIC_WRITE_MAX=60

# Payment endpoints
RATE_LIMIT_PAYMENT_WINDOW_MS=600000    # 10 minutes
RATE_LIMIT_PAYMENT_MAX=40

# Waiter-call endpoints
RATE_LIMIT_WAITER_WINDOW_MS=300000     # 5 minutes
RATE_LIMIT_WAITER_MAX=30
